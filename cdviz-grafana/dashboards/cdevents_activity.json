  "panels": [
    {
      "type": "volkovlabs-echarts-panel",
      "transparent": false,
      "repeatDirection": "h",
      "options": {
        "getOption": "// src/panels/browser_scripts/draw_sunburst_count_per_path_echarts.ts\nfunction dataFramesToDatums(series) {\n  if (!series?.length)\n    return [];\n  const frame = series[0];\n  const getField = (name) => frame.fields.find((f) => f.name === name);\n  const countField = getField(\"count\");\n  const pathField = getField(\"path\");\n  if (!countField || !pathField)\n    return [];\n  return pathField.values.map((path, i) => ({\n    count: Number(countField.values[i]),\n    path: path ?? \"\"\n  }));\n}\nfunction buildHierarchy(data) {\n  const root = { name: \"\", children: [] };\n  for (const { count, path } of data) {\n    const fragments = path.split(\"/\").filter((v) => !!v && !v.endsWith(\":\"));\n    if (fragments.length === 0)\n      continue;\n    let parent = root;\n    for (let i = 0;i < fragments.length - 1; i++) {\n      let node = parent.children?.find((d) => d.name === fragments[i]);\n      if (!node) {\n        node = { name: fragments[i], children: [] };\n        parent.children?.push(node);\n      } else if (!node.children) {\n        node.children = [];\n      }\n      parent = node;\n    }\n    const lastName = fragments[fragments.length - 1];\n    const existing = parent.children?.find((d) => d.name === lastName);\n    if (existing) {\n      existing.value = (existing.value ?? 0) + count;\n    } else {\n      parent.children?.push({ name: lastName, value: count });\n    }\n  }\n  return root.children ?? [];\n}\nfunction getOption(context) {\n  const datums = dataFramesToDatums(context.panel.data.series);\n  if (datums.length === 0) {\n    return {\n      title: {\n        text: \"No data\",\n        left: \"center\",\n        top: \"center\",\n        textStyle: { color: \"#aaaaaa\", fontSize: 16 }\n      }\n    };\n  }\n  const data = buildHierarchy(datums);\n  return {\n    backgroundColor: \"transparent\",\n    tooltip: {\n      trigger: \"item\",\n      formatter: (params) => {\n        const path = params.treePathInfo.map((n) => n.name).filter((n) => n).join(\" / \");\n        return `${path}<br/><b>${params.value}</b>`;\n      }\n    },\n    series: [\n      {\n        type: \"sunburst\",\n        data,\n        radius: [\"15%\", \"90%\"],\n        sort: \"desc\",\n        nodeClick: \"rootToNode\",\n        emphasis: {\n          focus: \"ancestor\"\n        },\n        label: {\n          show: true,\n          rotate: \"radial\",\n          fontSize: 11,\n          overflow: \"truncate\",\n          width: 70\n        },\n        levels: [\n          {},\n          {\n            label: {\n              rotate: \"tangential\",\n              fontSize: 12,\n              fontWeight: \"bold\"\n            },\n            itemStyle: { borderWidth: 2 }\n          },\n          {\n            label: { rotate: \"radial\", fontSize: 10 }\n          }\n        ]\n      }\n    ]\n  };\n}\nreturn getOption(context);\n",
        "renderer": "canvas",
        "editor": {
          "format": "javascript"
        }
      },
      "title": "How many events?",
      "description": "Count by Subject & Predicate over the time window",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  COUNT(*) as count,\n  subject || '/' || predicate as path\nFROM cdviz.cdevents_lake\nWHERE $__timeFilter(timestamp)\n  AND subject = ANY(ARRAY[${subjects:sqlstring}]::text[])\n  AND predicate = ANY(ARRAY[${predicates:sqlstring}]::text[])\nGROUP BY subject, predicate\nORDER BY subject, predicate",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ]
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Events By Hours",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barWidthFactor": 0.5,
            "drawStyle": "bars",
            "fillOpacity": 49
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  time_bucket('1 hour', timestamp) AS time,\n  (subject || '/' || predicate) AS kind,\n  COUNT(*)\nFROM cdviz.cdevents_lake\nWHERE $__timeFilter(timestamp)\n  AND subject = ANY(ARRAY[${subjects:sqlstring}]::text[])\n  AND predicate = ANY(ARRAY[${predicates:sqlstring}]::text[])\nGROUP BY time, kind\nORDER BY time, kind",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "transformations": [
        {
          "id": "partitionByValues",
          "options": {
            "fields": [
              "kind"
            ],
            "keepFields": false,
            "naming": {
              "asLabels": true
            }
          }
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "volkovlabs-echarts-panel",
      "transparent": false,
      "repeatDirection": "h",
      "options": {
        "getOption": "// src/panels/browser_scripts/draw_sunburst_count_per_path_echarts.ts\nfunction dataFramesToDatums(series) {\n  if (!series?.length)\n    return [];\n  const frame = series[0];\n  const getField = (name) => frame.fields.find((f) => f.name === name);\n  const countField = getField(\"count\");\n  const pathField = getField(\"path\");\n  if (!countField || !pathField)\n    return [];\n  return pathField.values.map((path, i) => ({\n    count: Number(countField.values[i]),\n    path: path ?? \"\"\n  }));\n}\nfunction buildHierarchy(data) {\n  const root = { name: \"\", children: [] };\n  for (const { count, path } of data) {\n    const fragments = path.split(\"/\").filter((v) => !!v && !v.endsWith(\":\"));\n    if (fragments.length === 0)\n      continue;\n    let parent = root;\n    for (let i = 0;i < fragments.length - 1; i++) {\n      let node = parent.children?.find((d) => d.name === fragments[i]);\n      if (!node) {\n        node = { name: fragments[i], children: [] };\n        parent.children?.push(node);\n      } else if (!node.children) {\n        node.children = [];\n      }\n      parent = node;\n    }\n    const lastName = fragments[fragments.length - 1];\n    const existing = parent.children?.find((d) => d.name === lastName);\n    if (existing) {\n      existing.value = (existing.value ?? 0) + count;\n    } else {\n      parent.children?.push({ name: lastName, value: count });\n    }\n  }\n  return root.children ?? [];\n}\nfunction getOption(context) {\n  const datums = dataFramesToDatums(context.panel.data.series);\n  if (datums.length === 0) {\n    return {\n      title: {\n        text: \"No data\",\n        left: \"center\",\n        top: \"center\",\n        textStyle: { color: \"#aaaaaa\", fontSize: 16 }\n      }\n    };\n  }\n  const data = buildHierarchy(datums);\n  return {\n    backgroundColor: \"transparent\",\n    tooltip: {\n      trigger: \"item\",\n      formatter: (params) => {\n        const path = params.treePathInfo.map((n) => n.name).filter((n) => n).join(\" / \");\n        return `${path}<br/><b>${params.value}</b>`;\n      }\n    },\n    series: [\n      {\n        type: \"sunburst\",\n        data,\n        radius: [\"15%\", \"90%\"],\n        sort: \"desc\",\n        nodeClick: \"rootToNode\",\n        emphasis: {\n          focus: \"ancestor\"\n        },\n        label: {\n          show: true,\n          rotate: \"radial\",\n          fontSize: 11,\n          overflow: \"truncate\",\n          width: 70\n        },\n        levels: [\n          {},\n          {\n            label: {\n              rotate: \"tangential\",\n              fontSize: 12,\n              fontWeight: \"bold\"\n            },\n            itemStyle: { borderWidth: 2 }\n          },\n          {\n            label: { rotate: \"radial\", fontSize: 10 }\n          }\n        ]\n      }\n    ]\n  };\n}\nreturn getOption(context);\n",
        "renderer": "canvas",
        "editor": {
          "format": "javascript"
        }
      },
      "title": "How many sources?",
      "description": "Count by Context'source over the time window",
