{
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 42,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "query": "grafana-postgresql-datasource",
        "regex": "cdviz.*",
        "hide": 3
      },
      {
        "type": "query",
        "name": "selected_value",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Incident",
        "datasource": {
          "type": "grafana-postgresql-datasource",
          "uid": "${datasource}"
        },
        "query": "SELECT DISTINCT payload -> 'subject' -> 'content' -> 'environment' ->> 'id' AS __value\nFROM cdviz.cdevents_lake\nWHERE $__timeFilter(timestamp)\nAND subject = 'incident'\nORDER BY __value",
        "sort": 5,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "constant",
        "name": "limit",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "hide": 2,
        "query": "20"
      }
    ]
  },
  "annotations": {},
  "title": "Incident: Executions",
  "uid": "incident_executions",
  "tags": [
    "incident"
  ],
  "time": {
    "from": "now-31d",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Incident: Overview",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Total Time to Resolve",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(SUM(extract('epoch' from (resolved_at - detected_at))), 0) AS total_duration\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])\n  AND resolved_at IS NOT NULL",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Avg Resolution Time",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(AVG(extract('epoch' from (resolved_at - detected_at))), 0) AS avg_runtime\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])\n  AND resolved_at IS NOT NULL",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Avg Time to Report",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(AVG(extract('epoch' from (reported_at - detected_at))), 0) AS avg_time_to_report\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])\n  AND reported_at IS NOT NULL\n  AND detected_at IS NOT NULL",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Resolution Rate",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(\n    100.0 * COUNT(*) FILTER (WHERE resolved_at IS NOT NULL) / NULLIF(COUNT(*), 0),\n    0\n  ) AS resolution_rate\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 75,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Incident Total Duration per Day",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT\n  time_bucket('1 day', resolved_at) AS time,\n  SUM(extract('epoch' from (resolved_at - detected_at))) AS total_duration\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])\n  AND resolved_at IS NOT NULL\nGROUP BY time\nORDER BY time",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "left",
            "axisWidth": 1,
            "barAlignment": 0,
            "barWidthFactor": 1,
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "opacity",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": [
            "sum",
            "max"
          ],
          "width": 300
        }
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Incident Total Number of Run per Day",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT\n  time_bucket('1 day', COALESCE(resolved_at, detected_at)) AS time,\n  CASE\n    WHEN resolved_at IS NOT NULL THEN 'resolved'\n    WHEN reported_at IS NOT NULL THEN 'reported'\n    WHEN detected_at IS NOT NULL THEN 'detected'\n    ELSE 'unknown'\n  END AS status,\n  COUNT(*) AS count\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])\nGROUP BY time, status\nORDER BY time, status",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "left",
            "axisWidth": 1,
            "barAlignment": 0,
            "barWidthFactor": 1,
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "opacity",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*(fail|error).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*(cancel|skip).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "semi-dark-orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*(pass|success|complet|resolved).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*detected.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*(reported|warn|withdrawn).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*(open|unknown|other).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*duplicate.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "gray"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": [
            "sum",
            "max"
          ],
          "width": 300
        }
      }
    },
    {
      "type": "row",
      "collapsed": true,
      "id": 0,
      "panels": [
        {
          "type": "table",
          "transparent": false,
          "repeatDirection": "h",
          "title": "$selected_value - Summary",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "targets": [
            {
              "format": "table",
              "rawSql": "SELECT\n  last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' AS \"Environment\",\n  subject_id AS \"ID\",\n  detected_at AS \"Started\",\n  resolved_at AS \"Completed\",\n  extract('epoch' from (resolved_at - detected_at)) AS \"Duration\",\n  CASE WHEN resolved_at IS NOT NULL THEN 'resolved' ELSE 'open' END AS \"Status\",\n  COALESCE(last_payload -> 'subject' -> 'content' ->> 'uri', last_payload -> 'subject' -> 'content' ->> 'url') AS \"URL\"\nFROM cdviz.incident\nWHERE\n  ($__timeFilter(detected_at) OR $__timeFilter(resolved_at))\n  AND last_payload -> 'subject' -> 'content' -> 'environment' ->> 'id' = ANY(ARRAY[${selected_value:sqlstring}]::text[])\nORDER BY resolved_at DESC NULLS FIRST\nLIMIT ${limit}",
              "datasource": {
                "type": "grafana-postgresql-datasource",
                "uid": "${datasource}"
              },
              "editorMode": "code",
              "rawQuery": true
            }
          ],
          "gridPos": {
            "h": 16,
            "w": 24,
            "x": 0,
            "y": 12
          },
          "fieldConfig": {
            "defaults": {},
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Duration"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "dtdurations"
                  }
                ]
              }
            ]
          }
        }
      ],
      "title": "Incident: Latest $limit Executions",
      "gridPos": {
        "x": 0,
        "y": 13,
        "h": 1,
        "w": 24
      }
    }
  ],
  "version": 2026031317
}
